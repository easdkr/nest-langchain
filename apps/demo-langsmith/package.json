{
  "name": "@nest-langchain/demo-langsmith",
  "version": "0.1.0",
  "private": true,
  "description": "LangSmith tracing demo for Nest LangChain.",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "pnpm --filter @nest-langchain/core build && pnpm --filter @nest-langchain/langsmith build",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "pnpm --filter @nest-langchain/core build && pnpm --filter @nest-langchain/langsmith build && tsx watch src/main.ts",
    "test": "vitest run --passWithNoTests",
    "pretypecheck": "pnpm --filter @nest-langchain/core build && pnpm --filter @nest-langchain/langsmith build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nest-langchain/core": "workspace:*",
    "@nest-langchain/langsmith": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "langsmith": "^0.7.10",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
