PORT=3000

# Optional model drafting. The app still works without these values and uses a
# deterministic fallback response.
OPENAI_API_KEY=

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# LangSmith tracing is optional for the demo.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nest-langchain-demo
LANGSMITH_ENDPOINT=
LANGSMITH_WORKSPACE_ID=
LANGCHAIN_CALLBACKS_BACKGROUND=true
