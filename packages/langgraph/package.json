{
  "name": "@nest-langchain/langgraph",
  "version": "0.3.4",
  "description": "LangGraph decorators and discovery integration for NestJS.",
  "license": "MIT",
  "author": "easdkr",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "pnpm --filter @nest-langchain/core build",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "pnpm --filter @nest-langchain/core build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.4",
    "@nest-langchain/core": "^0.1.4",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.4",
    "@nest-langchain/core": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-langchain.git",
    "directory": "packages/langgraph"
  },
  "homepage": "https://github.com/easdkr/nest-langchain#readme",
  "bugs": {
    "url": "https://github.com/easdkr/nest-langchain/issues"
  },
  "keywords": [
    "nestjs",
    "langchain",
    "langgraph",
    "graph",
    "agent"
  ]
}
