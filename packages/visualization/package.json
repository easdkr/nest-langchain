{
  "name": "@nest-langchain/visualization",
  "version": "0.1.3",
  "description": "Hosted graph documentation and layout APIs for Nest LangChain registries.",
  "license": "MIT",
  "author": "easdkr",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "pnpm --filter @nest-langchain/core build",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "pnpm --filter @nest-langchain/core build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@nest-langchain/core": "^0.1.4",
    "@nestjs/common": "^10 || ^11"
  },
  "peerDependenciesMeta": {
    "@mermaid-js/mermaid-cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nest-langchain/core": "workspace:*",
    "@nestjs/common": "^11.1.27"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-langchain.git",
    "directory": "packages/visualization"
  },
  "homepage": "https://github.com/easdkr/nest-langchain#readme",
  "bugs": {
    "url": "https://github.com/easdkr/nest-langchain/issues"
  },
  "keywords": [
    "nestjs",
    "langchain",
    "visualization",
    "graphs",
    "docs"
  ]
}
